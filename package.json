{
  "name": "@vindulaintranet/pi-extension-search",
  "version": "0.1.0",
  "description": "Pi package with web search tools powered by Exa and Brave Search",
  "author": "Fabio Rizzo Matos <fabiorizzo@vindula.com.br> (https://github.com/fabiorizzomatos)",
  "license": "MIT",
  "keywords": [
    "pi-package",
    "pi-extension",
    "search",
    "exa",
    "brave"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vindulaintranet/pi-extension-search.git"
  },
  "bugs": {
    "url": "https://github.com/vindulaintranet/pi-extension-search/issues"
  },
  "homepage": "https://github.com/vindulaintranet/pi-extension-search#readme",
  "scripts": {
    "test": "tsx --test test/**/*.test.ts",
    "check:bundle": "esbuild search.ts --bundle --platform=node --format=cjs --outfile=/tmp/pi-extension-search-check.js --external:@mariozechner/pi-coding-agent --external:@sinclair/typebox",
    "check:pack": "npm pack --dry-run",
    "validate": "npm test && npm run check:bundle && npm run check:pack"
  },
  "pi": {
    "extensions": [
      "./search.ts"
    ]
  },
  "files": [
    "search.ts",
    "search-core.ts",
    "README.md",
    "CHANGELOG.md",
    "LICENSE",
    "docs/agent/notes"
  ],
  "peerDependencies": {
    "@mariozechner/pi-coding-agent": "*",
    "@sinclair/typebox": "*"
  },
  "devDependencies": {
    "esbuild": "^0.25.11",
    "tsx": "^4.20.6"
  }
}
